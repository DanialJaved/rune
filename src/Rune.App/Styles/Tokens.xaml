<!-- Design tokens: the ONLY place new spacing/radius/size constants may be
     defined. GNOME-HIG-inspired scale (4/8/12/16/24) on Fluent controls. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Spacing scale -->
    <x:Double x:Key="SpaceXS">4</x:Double>
    <x:Double x:Key="SpaceS">8</x:Double>
    <x:Double x:Key="SpaceM">12</x:Double>
    <x:Double x:Key="SpaceL">16</x:Double>
    <x:Double x:Key="SpaceXL">24</x:Double>

    <!-- Header bar (Papers headerbar is 47px @1x; 44 reads right on Fluent) -->
    <x:Double x:Key="HeaderHeight">44</x:Double>
    <x:Double x:Key="IconButtonSize">34</x:Double>
    <x:Double x:Key="IconGlyphSize">16</x:Double>

    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusPill">18</CornerRadius>

    <!-- Homepage cards -->
    <x:Double x:Key="CardWidth">168</x:Double>
    <x:Double x:Key="CardHeight">212</x:Double>

    <!-- Sidebar -->
    <x:Double x:Key="SidebarWidth">280</x:Double>
    <x:Double x:Key="SidebarThumbWidth">168</x:Double>
</ResourceDictionary>
