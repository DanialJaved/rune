<Window
    x:Class="Rune.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Rune.Controls"
    xmlns:services="using:Rune.Services"
    Title="Rune">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        AllowDrop="True"
        KeyboardAcceleratorPlacementMode="Hidden"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Chrome-style: the tab strip IS the title bar. Tabs carry no
             content (documents render in DocHost below); the footer is the
             window drag region, padded clear of the caption buttons. -->
        <TabView
            x:Name="Tabs"
            Grid.Row="0"
            VerticalAlignment="Top"
            TabWidthMode="Equal"
            CloseButtonOverlayMode="Auto"
            SelectionChanged="Tabs_SelectionChanged"
            AddTabButtonClick="Tabs_AddTabButtonClick"
            TabCloseRequested="Tabs_TabCloseRequested">
            <TabView.TabStripHeader>
                <TextBlock
                    Text="Rune"
                    VerticalAlignment="Center"
                    Margin="14,0,10,0"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.8" />
            </TabView.TabStripHeader>
            <TabView.TabStripFooter>
                <Grid x:Name="TitleBarDragArea" Background="Transparent" MinWidth="188" />
            </TabView.TabStripFooter>
        </TabView>

        <!-- Toolbar: stock compact CommandBar (Windows 11 Notepad pattern) —
             uniform control sizing and automatic overflow on narrow windows. -->
        <CommandBar
            x:Name="Toolbar"
            Grid.Row="1"
            DefaultLabelPosition="Collapsed"
            IsDynamicOverflowEnabled="True"
            OverflowButtonVisibility="Auto"
            HorizontalAlignment="Left"
            Background="Transparent">

            <AppBarButton x:Name="OpenButton" Icon="OpenFile" Label="Open" Click="OpenButton_Click" ToolTipService.ToolTip="Open a PDF (Ctrl+O)">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="O" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarToggleButton x:Name="SidebarButton" Label="Sidebar" Click="SidebarButton_Click" IsEnabled="False" ToolTipService.ToolTip="Show sidebar (F9)">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE71C;" />
                </AppBarToggleButton.Icon>
                <AppBarToggleButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F9" />
                </AppBarToggleButton.KeyboardAccelerators>
            </AppBarToggleButton>

            <AppBarSeparator />

            <AppBarButton x:Name="BackButton" Icon="Back" Label="Back" Click="BackButton_Click" IsEnabled="False" ToolTipService.ToolTip="Back (Alt+Left)" />
            <AppBarButton x:Name="ForwardButton" Icon="Forward" Label="Forward" Click="ForwardButton_Click" IsEnabled="False" ToolTipService.ToolTip="Forward (Alt+Right)" />

            <AppBarSeparator />

            <AppBarButton x:Name="PrevButton" Label="Previous page" Click="PrevButton_Click" IsEnabled="False" ToolTipService.ToolTip="Previous page">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE70E;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarElementContainer VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <NumberBox
                        x:Name="PageBox"
                        Minimum="1"
                        SpinButtonPlacementMode="Hidden"
                        IsEnabled="False"
                        MinWidth="56"
                        VerticalAlignment="Center"
                        ValueChanged="PageBox_ValueChanged" />
                    <TextBlock
                        x:Name="PageCountLabel"
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Opacity="0.7" />
                </StackPanel>
            </AppBarElementContainer>
            <AppBarButton x:Name="NextButton" Label="Next page" Click="NextButton_Click" IsEnabled="False" ToolTipService.ToolTip="Next page">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE70D;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator />

            <AppBarButton x:Name="ZoomOutButton" Icon="ZoomOut" Label="Zoom out" Click="ZoomOutButton_Click" IsEnabled="False" ToolTipService.ToolTip="Zoom out (Ctrl+-)" />
            <AppBarElementContainer VerticalAlignment="Center">
                <TextBlock
                    x:Name="ZoomLabel"
                    Text="100%"
                    VerticalAlignment="Center"
                    MinWidth="44"
                    TextAlignment="Center"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Opacity="0.7" />
            </AppBarElementContainer>
            <AppBarButton x:Name="ZoomInButton" Icon="ZoomIn" Label="Zoom in" Click="ZoomInButton_Click" IsEnabled="False" ToolTipService.ToolTip="Zoom in (Ctrl++)" />
            <AppBarToggleButton x:Name="FitWidthButton" Label="Fit width" Click="FitWidthButton_Click" IsEnabled="False" ToolTipService.ToolTip="Fit width (Ctrl+2)">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE9A6;" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <AppBarToggleButton x:Name="FitPageButton" Label="Fit page" Click="FitPageButton_Click" IsEnabled="False" ToolTipService.ToolTip="Fit page (Ctrl+0)">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE9A6;" RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <RotateTransform Angle="90" />
                        </FontIcon.RenderTransform>
                    </FontIcon>
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>

            <AppBarSeparator />

            <AppBarButton x:Name="RotateButton" Icon="Rotate" Label="Rotate" Click="RotateButton_Click" IsEnabled="False" ToolTipService.ToolTip="Rotate (Ctrl+R)">
                <AppBarButton.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="R" />
                </AppBarButton.KeyboardAccelerators>
            </AppBarButton>
            <AppBarToggleButton x:Name="NightButton" Label="Night mode" Click="NightButton_Click" IsEnabled="False" ToolTipService.ToolTip="Night mode — invert page colors (Ctrl+I)">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE708;" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <AppBarToggleButton x:Name="InkButton" Label="Draw" Click="InkButton_Click" IsEnabled="False" ToolTipService.ToolTip="Draw with the pen (Ctrl+E)">
                <AppBarToggleButton.Icon>
                    <FontIcon Glyph="&#xE76D;" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>

            <AppBarSeparator />

            <AppBarButton x:Name="SaveButton" Icon="Save" Label="Save" Click="SaveButton_Click" IsEnabled="False" ToolTipService.ToolTip="Save (Ctrl+S)" />
            <AppBarButton x:Name="PrintButton" Label="Print" Click="PrintButton_Click" IsEnabled="False" ToolTipService.ToolTip="Print (Ctrl+P)">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE749;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="SaveAsButton" Label="Save As…" Click="SaveAsButton_Click" IsEnabled="False">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE792;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="InkOptionsButton" Label="Pen color &amp; width" IsEnabled="False">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE790;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="PropertiesButton" Label="Document properties" Click="PropertiesButton_Click" IsEnabled="False">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton x:Name="UpdatesButton" Label="Check for updates" Click="UpdatesButton_Click">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE895;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="SettingsButton" Icon="Setting" Label="Settings" Click="SettingsButton_Click" />
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <Grid Grid.Row="2">
            <!-- The selected tab's DocumentView is swapped in here. -->
            <ContentControl
                x:Name="DocHost"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />

            <!-- Start page: recents, shown when no tab is open -->
            <ScrollViewer x:Name="StartPage" HorizontalScrollMode="Disabled">
                <StackPanel MaxWidth="760" Margin="48,32" Spacing="20" HorizontalAlignment="Center">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Rune" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        <TextBlock Text="A fast, free PDF reader for Windows" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.7" />
                    </StackPanel>

                    <Button Click="OpenButton_Click" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                            <TextBlock Text="Open a PDF" />
                        </StackPanel>
                    </Button>

                    <!-- Recent thumbnails grid (optional; up to 6 cards) -->
                    <StackPanel x:Name="RecentThumbsSection" Spacing="8" Visibility="Collapsed">
                        <TextBlock Text="Recent" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <GridView
                            x:Name="RecentThumbs"
                            SelectionMode="None"
                            IsItemClickEnabled="True"
                            ItemClick="RecentThumbs_ItemClick">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="controls:RecentCard">
                                    <StackPanel Width="150" Margin="0,0,12,12" Spacing="6">
                                        <Border
                                            Width="150"
                                            Height="194"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            Background="White">
                                            <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="Uniform" />
                                        </Border>
                                        <TextBlock Text="{x:Bind DisplayName}" MaxWidth="150" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        <TextBlock Text="{x:Bind Folder}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.5" MaxWidth="150" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="RecentsHeader" Text="All recent" Style="{StaticResource SubtitleTextBlockStyle}" Visibility="Collapsed" />
                        <ItemsControl x:Name="RecentsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:RecentFile">
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Margin="0,2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="Recent_Click"
                                        Tag="{x:Bind Path}">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <FontIcon Glyph="&#xEA90;" FontSize="16" Opacity="0.7" />
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind DisplayName}" />
                                                <TextBlock Text="{x:Bind Path}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.5" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Find bar -->
            <Border
                x:Name="FindBar"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,8,16,0"
                Padding="6"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBox
                        x:Name="FindBox"
                        Width="220"
                        PlaceholderText="Find in document"
                        TextChanged="FindBox_TextChanged"
                        KeyDown="FindBox_KeyDown" />
                    <TextBlock
                        x:Name="FindCount"
                        VerticalAlignment="Center"
                        MinWidth="64"
                        Margin="4,0"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Opacity="0.7" />
                    <ToggleButton x:Name="MatchCaseButton" Click="MatchCase_Click" ToolTipService.ToolTip="Match case" Padding="8,4">
                        <TextBlock Text="Aa" FontSize="13" />
                    </ToggleButton>
                    <Button x:Name="FindPrev" Click="FindPrev_Click" ToolTipService.ToolTip="Previous (Shift+Enter)" Padding="8,4">
                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                    </Button>
                    <Button x:Name="FindNext" Click="FindNext_Click" ToolTipService.ToolTip="Next (Enter)" Padding="8,4">
                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                    </Button>
                    <Button x:Name="FindClose" Click="FindClose_Click" ToolTipService.ToolTip="Close (Esc)" Padding="8,4">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                    </Button>
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="ErrorBar"
                Severity="Error"
                VerticalAlignment="Bottom"
                Margin="24"
                IsOpen="False" />

            <controls:CommandPalette x:Name="Palette" />
        </Grid>
    </Grid>
</Window>
