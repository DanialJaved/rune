<Window
    x:Class="Rune.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Rune.Controls"
    Title="Rune">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        AllowDrop="True"
        KeyboardAcceleratorPlacementMode="Hidden"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Chrome-style: the tab strip IS the title bar. Tabs carry no
             content (documents render in DocHost below); the footer is the
             window drag region, padded clear of the caption buttons. -->
        <TabView
            x:Name="Tabs"
            Grid.Row="0"
            VerticalAlignment="Top"
            TabWidthMode="Equal"
            CloseButtonOverlayMode="Auto"
            SelectionChanged="Tabs_SelectionChanged"
            AddTabButtonClick="Tabs_AddTabButtonClick"
            TabCloseRequested="Tabs_TabCloseRequested">
            <TabView.TabStripHeader>
                <TextBlock
                    Text="Rune"
                    VerticalAlignment="Center"
                    Margin="14,0,10,0"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.8" />
            </TabView.TabStripHeader>
            <TabView.TabStripFooter>
                <Grid x:Name="TitleBarDragArea" Background="Transparent" MinWidth="188" />
            </TabView.TabStripFooter>
        </TabView>

        <!-- Header bar (GNOME Papers proportions): one slim row of flat icon
             buttons; everything else lives in the hamburger menu. -->
        <Grid
            x:Name="Toolbar"
            Grid.Row="1"
            Height="{StaticResource HeaderHeight}"
            Padding="8,0"
            ColumnSpacing="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ToggleButton
                x:Name="SidebarButton"
                Grid.Column="0"
                Style="{StaticResource IconToggleButtonStyle}"
                Click="SidebarButton_Click"
                IsEnabled="False"
                ToolTipService.ToolTip="Show sidebar (F9)">
                <FontIcon Glyph="&#xE8A0;" FontSize="{StaticResource IconGlyphSize}" />
            </ToggleButton>

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="6"
                Margin="8,0,0,0"
                VerticalAlignment="Center">
                <NumberBox
                    x:Name="PageBox"
                    Minimum="1"
                    SpinButtonPlacementMode="Hidden"
                    IsEnabled="False"
                    MinWidth="52"
                    VerticalAlignment="Center"
                    ValueChanged="PageBox_ValueChanged" />
                <TextBlock
                    x:Name="PageCountLabel"
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.7" />
            </StackPanel>

            <Button
                x:Name="FindButton"
                Grid.Column="3"
                Style="{StaticResource IconButtonStyle}"
                Click="FindButton_Click"
                IsEnabled="False"
                ToolTipService.ToolTip="Find in document (Ctrl+F)">
                <FontIcon Glyph="&#xE721;" FontSize="{StaticResource IconGlyphSize}" />
            </Button>
            <ToggleButton
                x:Name="InkButton"
                Grid.Column="4"
                Style="{StaticResource IconToggleButtonStyle}"
                Click="InkButton_Click"
                IsEnabled="False"
                ToolTipService.ToolTip="Draw with the pen (Ctrl+E)">
                <FontIcon Glyph="&#xE76D;" FontSize="{StaticResource IconGlyphSize}" />
            </ToggleButton>
            <ToggleButton
                x:Name="NightButton"
                Grid.Column="5"
                Style="{StaticResource IconToggleButtonStyle}"
                Click="NightButton_Click"
                IsEnabled="False"
                ToolTipService.ToolTip="Night mode — invert page colors (Ctrl+I)">
                <FontIcon Glyph="&#xE708;" FontSize="{StaticResource IconGlyphSize}" />
            </ToggleButton>
            <Button
                x:Name="MenuButton"
                Grid.Column="6"
                Style="{StaticResource IconButtonStyle}"
                ToolTipService.ToolTip="Menu">
                <FontIcon Glyph="&#xE700;" FontSize="{StaticResource IconGlyphSize}" />
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <MenuFlyoutItem x:Name="OpenMenuItem" Text="Open…" Click="OpenButton_Click" KeyboardAcceleratorTextOverride="Ctrl+O">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8E5;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="UndoMenuItem" Text="Undo" Click="UndoMenuItem_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+Z">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7A7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="RedoMenuItem" Text="Redo" Click="RedoMenuItem_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+Y">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7A6;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="SaveMenuItem" Text="Save" Click="SaveButton_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+S">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74E;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SaveAsMenuItem" Text="Save as…" Click="SaveAsButton_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+Shift+S">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE792;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="PrintMenuItem" Text="Print…" Click="PrintButton_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+P">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE749;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="RotateMenuItem" Text="Rotate" Click="RotateButton_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+R">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7AD;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem x:Name="InkOptionsMenuItem" Text="Pen color and width" IsEnabled="False">
                            <MenuFlyoutSubItem.Icon>
                                <FontIcon Glyph="&#xE790;" />
                            </MenuFlyoutSubItem.Icon>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutItem x:Name="PresentMenuItem" Text="Presentation" Click="PresentMenuItem_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="F5">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7F4;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="PropertiesMenuItem" Text="Document properties" Click="PropertiesButton_Click" IsEnabled="False" KeyboardAcceleratorTextOverride="Ctrl+D">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE946;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="ShortcutsMenuItem" Text="Keyboard shortcuts" Click="ShortcutsMenuItem_Click" KeyboardAcceleratorTextOverride="F1">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE765;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="UpdatesMenuItem" Text="Check for updates" Click="UpdatesButton_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE895;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SettingsMenuItem" Text="Settings" Click="SettingsButton_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE713;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Grid Grid.Row="2">
            <!-- The selected tab's DocumentView is swapped in here. -->
            <ContentControl
                x:Name="DocHost"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />

            <!-- Start page: recent documents grid (GNOME Papers recent view) -->
            <Grid x:Name="StartPage" Padding="32,24,32,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" MaxWidth="936" Margin="0,0,0,16">
                    <TextBlock
                        x:Name="RecentsHeader"
                        Text="Recent documents"
                        VerticalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Button
                        HorizontalAlignment="Right"
                        Click="OpenButton_Click"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                            <TextBlock Text="Open a PDF" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled">
                    <GridView
                        x:Name="RecentThumbs"
                        MaxWidth="936"
                        Margin="0,0,0,24"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemClick="RecentThumbs_ItemClick">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="controls:RecentCard">
                                <StackPanel Width="168" Margin="0,0,8,8" Spacing="6">
                                    <Grid Width="168" Height="212" Style="{StaticResource CardSurfaceStyle}">
                                        <FontIcon
                                            Glyph="&#xEA90;"
                                            FontSize="32"
                                            Opacity="0.25"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind ShowPlaceholder, Mode=OneWay}" />
                                        <Image
                                            Source="{x:Bind Thumbnail, Mode=OneWay}"
                                            Stretch="Uniform"
                                            Margin="1"
                                            Visibility="{x:Bind HasThumbnail, Mode=OneWay}" />
                                    </Grid>
                                    <TextBlock Text="{x:Bind DisplayName}" MaxWidth="168" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                    <TextBlock Text="{x:Bind Folder}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.5" MaxWidth="168" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,-4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </ScrollViewer>

                <!-- Shown instead of the grid when there is nothing recent. -->
                <StackPanel
                    x:Name="EmptyState"
                    Grid.Row="1"
                    Spacing="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <FontIcon Glyph="&#xEA90;" FontSize="48" Opacity="0.25" HorizontalAlignment="Center" />
                    <TextBlock
                        Text="No recent documents"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Opacity="0.7" />
                    <TextBlock
                        Text="Open a PDF to get started"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Opacity="0.5" />
                </StackPanel>
            </Grid>

            <!-- Floating zoom pill (Papers-style, bottom-right over the page) -->
            <Border
                x:Name="ZoomPill"
                Style="{StaticResource OverlayPillStyle}"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Height="38"
                Padding="4,0">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button
                        x:Name="ZoomOutButton"
                        Style="{StaticResource PillButtonStyle}"
                        Click="ZoomOutButton_Click"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Zoom out (Ctrl+-)">
                        <FontIcon Glyph="&#xE738;" FontSize="14" />
                    </Button>
                    <Button
                        x:Name="ZoomLabelButton"
                        Background="Transparent"
                        BorderThickness="0"
                        Height="30"
                        MinWidth="52"
                        Padding="6,0"
                        CornerRadius="15"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Zoom level">
                        <TextBlock x:Name="ZoomLabel" Text="100%" Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem Text="50%" Click="ZoomPreset_Click" Tag="0.5" />
                                <MenuFlyoutItem Text="100%" Click="ZoomPreset_Click" Tag="1.0" KeyboardAcceleratorTextOverride="Ctrl+1" />
                                <MenuFlyoutItem Text="150%" Click="ZoomPreset_Click" Tag="1.5" />
                                <MenuFlyoutItem Text="200%" Click="ZoomPreset_Click" Tag="2.0" />
                                <MenuFlyoutSeparator />
                                <ToggleMenuFlyoutItem x:Name="FitWidthItem" Text="Fit width" Click="FitWidthButton_Click" KeyboardAcceleratorTextOverride="Ctrl+2" />
                                <ToggleMenuFlyoutItem x:Name="FitPageItem" Text="Fit page" Click="FitPageButton_Click" KeyboardAcceleratorTextOverride="Ctrl+0" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button
                        x:Name="ZoomInButton"
                        Style="{StaticResource PillButtonStyle}"
                        Click="ZoomInButton_Click"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Zoom in (Ctrl++)">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Find bar -->
            <Border
                x:Name="FindBar"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,8,16,0"
                Padding="6"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBox
                        x:Name="FindBox"
                        Width="220"
                        PlaceholderText="Find in document"
                        TextChanged="FindBox_TextChanged"
                        KeyDown="FindBox_KeyDown" />
                    <TextBlock
                        x:Name="FindCount"
                        VerticalAlignment="Center"
                        MinWidth="64"
                        Margin="4,0"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Opacity="0.7" />
                    <ToggleButton x:Name="MatchCaseButton" Click="MatchCase_Click" ToolTipService.ToolTip="Match case" Padding="8,4">
                        <TextBlock Text="Aa" FontSize="13" />
                    </ToggleButton>
                    <Button x:Name="FindPrev" Click="FindPrev_Click" ToolTipService.ToolTip="Previous (Shift+Enter)" Padding="8,4">
                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                    </Button>
                    <Button x:Name="FindNext" Click="FindNext_Click" ToolTipService.ToolTip="Next (Enter)" Padding="8,4">
                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                    </Button>
                    <Button x:Name="FindClose" Click="FindClose_Click" ToolTipService.ToolTip="Close (Esc)" Padding="8,4">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                    </Button>
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="ErrorBar"
                Severity="Error"
                VerticalAlignment="Bottom"
                Margin="24"
                IsOpen="False" />

            <controls:CommandPalette x:Name="Palette" />
        </Grid>

        <!-- Fullscreen presentation overlay: covers ALL rows (tabs included). -->
        <controls:PresentationView
            x:Name="Presentation"
            Grid.Row="0"
            Grid.RowSpan="3" />
    </Grid>
</Window>
