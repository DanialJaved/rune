<UserControl
    x:Class="Rune.Controls.DocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Rune.Controls">

    <SplitView
        x:Name="Split"
        DisplayMode="Inline"
        PanePlacement="Left"
        OpenPaneLength="240"
        IsPaneOpen="False">

        <SplitView.Pane>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Padding="8,8,8,4">
                    <ToggleButton x:Name="ThumbsTab" Content="Thumbnails" IsChecked="True" Click="ThumbsTab_Click" />
                    <ToggleButton x:Name="OutlineTab" Content="Contents" Click="OutlineTab_Click" />
                </StackPanel>

                <ListView
                    x:Name="ThumbList"
                    Grid.Row="1"
                    SelectionMode="Single"
                    Padding="4"
                    ContainerContentChanging="ThumbList_ContainerContentChanging"
                    SelectionChanged="ThumbList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="controls:ThumbnailItem">
                            <StackPanel HorizontalAlignment="Center" Spacing="2" Padding="0,4">
                                <Border
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="White"
                                    Width="120"
                                    MinHeight="150">
                                    <Image Source="{x:Bind Image, Mode=OneWay}" Stretch="Uniform" />
                                </Border>
                                <TextBlock
                                    Text="{x:Bind Label}"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Opacity="0.7" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TreeView
                    x:Name="OutlineTree"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    SelectionMode="Single"
                    ItemInvoked="OutlineTree_ItemInvoked">
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="controls:OutlineNode">
                            <TreeViewItem
                                ItemsSource="{x:Bind Children}"
                                IsExpanded="False">
                                <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <TextBlock
                    x:Name="NoOutlineLabel"
                    Grid.Row="1"
                    Text="No table of contents"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.5" />
            </Grid>
        </SplitView.Pane>

        <controls:PdfViewer x:Name="ViewerControl" />
    </SplitView>
</UserControl>
