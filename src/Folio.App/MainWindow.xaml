<Window
    x:Class="Folio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Folio.Controls"
    xmlns:services="using:Folio.Services"
    Title="Folio">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <TextBlock
                x:Name="TitleText"
                Text="Folio"
                VerticalAlignment="Center"
                Margin="16,0,0,0"
                Style="{StaticResource CaptionTextBlockStyle}" />
        </Grid>

        <!-- Toolbar -->
        <StackPanel
            x:Name="Toolbar"
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="4"
            Padding="12,4">
            <Button x:Name="OpenButton" Click="OpenButton_Click" ToolTipService.ToolTip="Open a PDF (Ctrl+O)">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    <TextBlock Text="Open" />
                </StackPanel>
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="O" />
                </Button.KeyboardAccelerators>
            </Button>

            <ToggleButton x:Name="SidebarButton" Click="SidebarButton_Click" IsEnabled="False" ToolTipService.ToolTip="Show sidebar (F9)">
                <FontIcon Glyph="&#xE71C;" FontSize="14" />
                <ToggleButton.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F9" />
                </ToggleButton.KeyboardAccelerators>
            </ToggleButton>

            <AppBarSeparator />

            <Button x:Name="BackButton" Click="BackButton_Click" IsEnabled="False" ToolTipService.ToolTip="Back (Alt+Left)">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>
            <Button x:Name="ForwardButton" Click="ForwardButton_Click" IsEnabled="False" ToolTipService.ToolTip="Forward (Alt+Right)">
                <FontIcon Glyph="&#xE72A;" FontSize="14" />
            </Button>

            <AppBarSeparator />

            <Button x:Name="PrevButton" Click="PrevButton_Click" IsEnabled="False" ToolTipService.ToolTip="Previous page">
                <FontIcon Glyph="&#xE70E;" FontSize="14" />
            </Button>
            <NumberBox
                x:Name="PageBox"
                Minimum="1"
                SpinButtonPlacementMode="Hidden"
                IsEnabled="False"
                MinWidth="64"
                VerticalAlignment="Center"
                ValueChanged="PageBox_ValueChanged" />
            <TextBlock
                x:Name="PageCountLabel"
                VerticalAlignment="Center"
                Margin="4,0,0,0"
                Style="{StaticResource BodyTextBlockStyle}"
                Opacity="0.7" />
            <Button x:Name="NextButton" Click="NextButton_Click" IsEnabled="False" ToolTipService.ToolTip="Next page">
                <FontIcon Glyph="&#xE70D;" FontSize="14" />
            </Button>

            <AppBarSeparator />

            <Button x:Name="ZoomOutButton" Click="ZoomOutButton_Click" IsEnabled="False" ToolTipService.ToolTip="Zoom out (Ctrl+-)">
                <FontIcon Glyph="&#xE71F;" FontSize="14" />
            </Button>
            <TextBlock
                x:Name="ZoomLabel"
                Text="100%"
                VerticalAlignment="Center"
                MinWidth="44"
                TextAlignment="Center"
                Style="{StaticResource BodyTextBlockStyle}"
                Opacity="0.7" />
            <Button x:Name="ZoomInButton" Click="ZoomInButton_Click" IsEnabled="False" ToolTipService.ToolTip="Zoom in (Ctrl++)">
                <FontIcon Glyph="&#xE8A3;" FontSize="14" />
            </Button>
            <ToggleButton x:Name="FitWidthButton" Click="FitWidthButton_Click" IsEnabled="False" ToolTipService.ToolTip="Fit width (Ctrl+2)">
                <FontIcon Glyph="&#xE9A6;" FontSize="14" />
            </ToggleButton>
            <ToggleButton x:Name="FitPageButton" Click="FitPageButton_Click" IsEnabled="False" ToolTipService.ToolTip="Fit page (Ctrl+0)">
                <FontIcon Glyph="&#xE9A6;" FontSize="14" RenderTransformOrigin="0.5,0.5">
                    <FontIcon.RenderTransform>
                        <RotateTransform Angle="90" />
                    </FontIcon.RenderTransform>
                </FontIcon>
            </ToggleButton>

            <AppBarSeparator />

            <Button x:Name="RotateButton" Click="RotateButton_Click" IsEnabled="False" ToolTipService.ToolTip="Rotate (Ctrl+R)">
                <FontIcon Glyph="&#xE7AD;" FontSize="14" />
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="R" />
                </Button.KeyboardAccelerators>
            </Button>
        </StackPanel>

        <Grid Grid.Row="2">
            <TabView
                x:Name="Tabs"
                VerticalAlignment="Stretch"
                TabWidthMode="Equal"
                CloseButtonOverlayMode="Auto"
                SelectionChanged="Tabs_SelectionChanged"
                AddTabButtonClick="Tabs_AddTabButtonClick"
                TabCloseRequested="Tabs_TabCloseRequested" />

            <!-- Start page: recents, shown when no tab is open -->
            <ScrollViewer x:Name="StartPage" HorizontalScrollMode="Disabled">
                <StackPanel MaxWidth="720" Margin="48,32" Spacing="20" HorizontalAlignment="Center">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Folio" Style="{StaticResource TitleLargeTextBlockStyle}" />
                        <TextBlock Text="A fast, free PDF reader for Windows" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.7" />
                    </StackPanel>

                    <Button Click="OpenButton_Click" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                            <TextBlock Text="Open a PDF" />
                        </StackPanel>
                    </Button>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="RecentsHeader" Text="Recent" Style="{StaticResource SubtitleTextBlockStyle}" Visibility="Collapsed" />
                        <ItemsControl x:Name="RecentsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:RecentFile">
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Margin="0,2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="Recent_Click"
                                        Tag="{x:Bind Path}">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <FontIcon Glyph="&#xEA90;" FontSize="16" Opacity="0.7" />
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind DisplayName}" />
                                                <TextBlock Text="{x:Bind Path}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.5" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Find bar -->
            <Border
                x:Name="FindBar"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,8,16,0"
                Padding="6"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBox
                        x:Name="FindBox"
                        Width="220"
                        PlaceholderText="Find in document"
                        TextChanged="FindBox_TextChanged"
                        KeyDown="FindBox_KeyDown" />
                    <TextBlock
                        x:Name="FindCount"
                        VerticalAlignment="Center"
                        MinWidth="64"
                        Margin="4,0"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Opacity="0.7" />
                    <ToggleButton x:Name="MatchCaseButton" Click="MatchCase_Click" ToolTipService.ToolTip="Match case" Padding="8,4">
                        <TextBlock Text="Aa" FontSize="13" />
                    </ToggleButton>
                    <Button x:Name="FindPrev" Click="FindPrev_Click" ToolTipService.ToolTip="Previous (Shift+Enter)" Padding="8,4">
                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                    </Button>
                    <Button x:Name="FindNext" Click="FindNext_Click" ToolTipService.ToolTip="Next (Enter)" Padding="8,4">
                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                    </Button>
                    <Button x:Name="FindClose" Click="FindClose_Click" ToolTipService.ToolTip="Close (Esc)" Padding="8,4">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                    </Button>
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="ErrorBar"
                Severity="Error"
                VerticalAlignment="Bottom"
                Margin="24"
                IsOpen="False" />
        </Grid>
    </Grid>
</Window>
